{
  "name": "lunivert-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "db:init": "psql -d $npm_config_db -f database/schema.sql",
    "db:seed": "node database/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
